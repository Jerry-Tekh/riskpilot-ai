{
  "name": "riskpilot-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:deploy": "prisma db push --accept-data-loss",
    "start:prod": "prisma db push --accept-data-loss && node prisma/seedIfEmpty.js && node src/index.js",
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^2.1.8"
  }
}
